class Solution {

    subsetSums(arr, n) {

        let result = [];

        const dfs = (index, sum) => {

            if (index === n) {
                result.push(sum);
                return;
            }

            dfs(index + 1, sum + arr[index]);

            dfs(index + 1, sum);
        };

        dfs(0, 0);

        result.sort((a, b) => a - b);

        return result;
    }
}
