var getPermutation = function(n, k) {

    let numbers = [];
    let factorial = [1];

    for (let i = 1; i <= n; i++) {
        numbers.push(i);
        factorial[i] = factorial[i - 1] * i;
    }

    k--;

    let result = "";

    for (let i = n; i >= 1; i--) {

        let index = Math.floor(
            k / factorial[i - 1]
        );

        result += numbers[index];

        numbers.splice(index, 1);

        k %= factorial[i - 1];
    }

    return result;
};
