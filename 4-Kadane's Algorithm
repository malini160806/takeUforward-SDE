function maxSubArray(nums) {
    let maxSum = nums[0];
    let currentSum = 0;

    for (let num of nums) {
        currentSum += num;

        maxSum = Math.max(maxSum, currentSum);

        if (currentSum < 0) {
            currentSum = 0;
        }
    }

    return maxSum;
}
console.log(maxSubArray([-2,1,-3,4,-1,2,1,-5,4]));
